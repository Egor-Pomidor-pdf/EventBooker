
ENV=debug

SERVER_HOST=0.0.0.0
SERVER_PORT=8089

POSTGRES_USER=eventbooker
POSTGRES_PASSWORD=eventbooker
POSTGRES_DB=eventbooker

POSTGRES_MASTER_DSN=postgres://eventbooker:eventbooker@postgres_master:5432/eventbooker?sslmode=disable
POSTGRES_SLAVE_DSNS=
POSTGRES_MAX_OPEN_CONNECTIONS=20
POSTGRES_MAX_IDLE_CONNECTIONS=5
POSTGRES_CONNECTION_MAX_LIFETIME_SECONDS=300

RETRY_POSTGRES_ATTEMPTS=5
RETRY_POSTGRES_DELAY_MS=500
RETRY_POSTGRES_BACKOFF=2
